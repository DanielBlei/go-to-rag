FROM llama3.1:8b

# Low temperature: factual grounding over creativity
# RAG answers must be deterministic
PARAMETER temperature    0.1

# Large context window
PARAMETER num_ctx        32768

# Force all layers onto GPU — prevents CPU offloading
PARAMETER num_gpu        99

# These three control how "creative" the word selection is.
# top_k + top_p: at each word, only consider the most likely candidates — keeps answers focused.
# repeat_penalty: discourages the model from copy-pasting the source text back verbatim.
PARAMETER top_k          40
PARAMETER top_p          0.9
PARAMETER repeat_penalty 1.05

# TODO: review and tighten the system prompt once the RAG pipeline is operational.
SYSTEM """
You are a helpful assistant with deep knowledge of software and AI systems.
Answer questions clearly and concisely.
"""